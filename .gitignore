# Deny everything by default.
# Add explicit exceptions as the project grows (source files, assets, config).
# Never add exceptions for: Sources/, ANALYSE_SOURCES.md, CLAUDE.md, .claude/
*

!.gitignore

# Project files
!.github/
!.github/workflows/
!.github/workflows/ci.yml
!.github/workflows/jellyfin-web-drift.yml
!.github/workflows/docs.yml
!.github/scripts/
!.github/scripts/update-manifest.py
!README.md
!CONTRIBUTING.md
!CHANGELOG.md
!LICENSE.md
!build.yaml
!manifest.json
!.releaserc.json
!package.json
!package-lock.json
!vitest.config.js
!mkdocs.yml

# Documentation assets
!docs/
docs/*
!docs/icon.png
!docs/banner.png
!docs/screenshots/
docs/screenshots/*
!docs/screenshots/home.png
!docs/screenshots/admin.png

# MkDocs site source (Phase 13 of TODO_V2.md)
!docs/index.md
!docs/configuration.md
!docs/troubleshooting.md
!docs/widgets/
docs/widgets/*
!docs/widgets/native/
docs/widgets/native/*
!docs/widgets/native/*.md
!docs/widgets/admin/
docs/widgets/admin/*
!docs/widgets/admin/*.md
!docs/widgets/personalized/
docs/widgets/personalized/*
!docs/widgets/personalized/*.md
!docs/widgets/connected/
docs/widgets/connected/*
!docs/widgets/connected/*.md

# Docker dev environment
!docker/
docker/*
!docker/docker-compose.yml
!docker/.env.example
!docker/scripts/
docker/scripts/*
!docker/scripts/deploy-plugin.ps1
!docker/plugins/
docker/plugins/*
!docker/plugins/.gitkeep
!docker/config/
docker/config/*
!docker/config/.gitkeep
!docker/cache/
docker/cache/*
!docker/cache/.gitkeep

# .NET solution and plugin source
!JellyUX-Homepage.sln
!src/
src/**
!src/**/
!src/**/*.cs
!src/**/*.csproj
!src/**/*.js
!src/**/*.css
!src/**/*.html
!src/**/appsettings*.json
!src/**/Localization/*.json
src/**/bin/
src/**/obj/

# Vitest tests for front-end pure functions (TODO_V2.md Phase 15.3)
!test/
test/*
!test/*.js
